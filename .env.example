# ── Cuerate RE Agent — environment ───────────────────────────────────────────
# Copy this file to `.env` and fill it in. You need exactly ONE key: OPENROUTER_API_KEY.
# One OpenRouter key reaches Claude, GPT, Gemini and image models through one endpoint.

# ═══ THE ONLY REQUIRED KEY ═══════════════════════════════════════════════════
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional — override if you use a proxy/self-host of the OpenRouter API.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Which models make up the ensemble (Stage 1) ──────────────────────────────
# Comma-separated OpenRouter model slugs. Each runs independently; their agreement is
# the confidence signal. Defaults to a multi-vendor mix. A bad slug fails gracefully.
# ENSEMBLE_MODELS=anthropic/claude-sonnet-5,openai/gpt-5.6-luna,google/gemini-3.5-flash

# The model that merges the ensemble into the final scored JSON (Stage 1.5).
# AGGREGATOR_MODEL=anthropic/claude-sonnet-5

# ── Stage 2 real verification (optional) ─────────────────────────────────────
# Set to an OpenRouter image-capable slug to turn ON the regenerate-and-compare trust
# loop. Leave blank for the (honest, labeled) agreement-based trust score.
# IMAGE_GEN_MODEL=google/gemini-3.1-flash-image

# ── Payment (x402 · OKX A2MCP) ───────────────────────────────────────────────
# Price per full reverse-engineer call. Stage-0 /identify is always free.
RE_PRICE_USD=0.35
PAYMENT_ASSET=USDT
PAYMENT_CHAIN=X Layer
# Your OKX Agentic Wallet address (where payments land). NOT an OpenRouter key — you get
# this from OKX when you list. A placeholder is fine for local dev/demo.
PAYMENT_ADDRESS=0xYOUR_OKX_AGENTIC_WALLET_ADDRESS

# Dev mode runs the paid endpoint locally without real onchain settlement.
# Set to "false" in production ONLY after the live x402 vars below are set — the server
# refuses to boot in live mode if any are missing (so it never advertises an unpayable price).
PAYMENT_DEV_MODE=true
PAYMENT_DEV_TOKEN=dev-okx-demo-token

# ── Live x402 settlement (required when PAYMENT_DEV_MODE=false) ───────────────
# The paid endpoint verifies + settles each call through the OKX x402 facilitator
# (POST /api/v6/pay/x402/verify → /settle). These are OKX API keys from your OKX API
# console — NOT the wallet, NOT OpenRouter. Docs: web3.okx.com/onchainos/dev-docs/payments
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
# OKX_API_BASE_URL=https://web3.okx.com

# x402 network id OKX expects (not the human "X Layer" label). Confirm in OKX docs/console.
PAYMENT_NETWORK=xlayer
# ERC-20 contract of the payout token (USDT on X Layer). Required in live mode — copy the
# exact address from OKX's token list / your ASP dashboard.
PAYMENT_ASSET_ADDRESS=
# Token decimals (USDT/USDC = 6). Used to convert the price to atomic units.
PAYMENT_ASSET_DECIMALS=6
# How long a 402 quote stays payable, in seconds.
PAYMENT_MAX_TIMEOUT_SECONDS=300

# ── Misc ─────────────────────────────────────────────────────────────────────
PORT=8787
# Passes used only by offline MOCK mode:
ENSEMBLE_SIZE=3
# Set MOCK_LLM=true to run the whole pipeline offline with no key (demo/CI).
# MOCK_LLM=false
